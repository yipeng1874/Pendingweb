  once
  daily
  weekly
  workday
}

// ════════════════════════════════════════════════════════════
// 厅管日常任务体系（独立于主播任务，以团队为管理中心）
// ════════════════════════════════════════════════════════════

/// 厅管日常任务模板（归属于 TEAM 类型组织，由团队管理员维护）
model HallTaskTemplate {
  id          String                 @id @default(uuid())
  title       String
  description String?                @db.Text
  teamOrgId   String                 @map("team_org_id")
  createdBy   String                 @map("created_by")
  version     Int                    @default(1)
  status      HallTaskTemplateStatus @default(draft)
  createdAt   DateTime               @default(now()) @map("created_at")
  updatedAt   DateTime               @updatedAt @map("updated_at")
  teamOrg     OrgUnit                @relation("HallTaskTemplateTeam", fields: [teamOrgId], references: [id])
  items       HallTaskItem[]
  assignments HallTaskAssignment[]

  @@index([teamOrgId])
  @@index([status])
  @@map("hall_task_templates")
}

/// 厅管日常任务模板题目
model HallTaskItem {
  id          String               @id @default(uuid())
  templateId  String               @map("template_id")
  sortOrder   Int                  @map("sort_order")
  itemType    HallTaskItemType     @map("item_type")
  title       String
  isRequired  Boolean              @default(true) @map("is_required")
  linkUrl     String?              @map("link_url")
  template    HallTaskTemplate     @relation(fields: [templateId], references: [id])
  options     HallTaskItemOption[]
  itemRecords HallTaskItemRecord[]

  @@index([templateId])
  @@map("hall_task_items")
}

/// 厅管日常任务模板题目选项
model HallTaskItemOption {
  id         String       @id @default(uuid())
  taskItemId String       @map("task_item_id")
  sortOrder  Int          @map("sort_order")
  label      String
  taskItem   HallTaskItem @relation(fields: [taskItemId], references: [id])

  @@index([taskItemId])
  @@map("hall_task_item_options")
}

/// 厅管日常任务发布（归属于团队，目标是团队下的各个 HALL 组织）
model HallTaskAssignment {
  id              String                   @id @default(uuid())
  templateId      String                   @map("template_id")
  teamOrgId       String                   @map("team_org_id")
  status          HallTaskAssignmentStatus @default(draft)
  effectMode      HallTaskEffectMode       @default(immediate) @map("effect_mode")
  effectiveAt     DateTime?                @map("effective_at")
  publishedAt     DateTime?                @map("published_at")
  endedAt         DateTime?                @map("ended_at")
  createdBy       String                   @map("created_by")
  createdByOrgId  String                   @map("created_by_org_id")
  createdAt       DateTime                 @default(now()) @map("created_at")
  updatedAt       DateTime                 @updatedAt @map("updated_at")
  template        HallTaskTemplate         @relation(fields: [templateId], references: [id])
  teamOrg         OrgUnit                  @relation("HallTaskAssignmentTeam", fields: [teamOrgId], references: [id])
  targets         HallTaskAssignmentTarget[]
  records         HallTaskRecord[]

  @@index([templateId])
  @@index([teamOrgId, status])
  @@index([createdAt])
  @@map("hall_task_assignments")
}

/// 厅管日常任务发布目标（具体的 HALL 组织）
model HallTaskAssignmentTarget {
  id              String             @id @default(uuid())
  assignmentId    String             @map("assignment_id")
  hallOrgId       String             @map("hall_org_id")
  createdAt       DateTime           @default(now()) @map("created_at")
  assignment      HallTaskAssignment @relation(fields: [assignmentId], references: [id])
  hallOrg         OrgUnit            @relation("HallTaskTarget", fields: [hallOrgId], references: [id])

  @@unique([assignmentId, hallOrgId])
  @@index([assignmentId])
  @@index([hallOrgId])
  @@map("hall_task_assignment_targets")
}

/// 厅管日常任务执行记录（主体是 HALL 组织，每日一条）
model HallTaskRecord {
  id             String               @id @default(uuid())
  assignmentId   String               @map("assignment_id")
  hallOrgId      String               @map("hall_org_id")
  recordDate     String               @map("record_date")
  status         HallTaskRecordStatus @default(pending)
  totalItems     Int                  @default(0) @map("total_items")
  doneItems      Int                  @default(0) @map("done_items")
  submittedAt    DateTime?            @map("submitted_at")
  submittedBy    String?              @map("submitted_by")
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")
  assignment     HallTaskAssignment   @relation(fields: [assignmentId], references: [id])
  hallOrg        OrgUnit              @relation("HallTaskRecordHall", fields: [hallOrgId], references: [id])
  itemRecords    HallTaskItemRecord[]
  leaveRequests  HallTaskLeaveRequest[]

  @@unique([assignmentId, hallOrgId, recordDate])
  @@index([assignmentId])
  @@index([hallOrgId])
  @@index([recordDate])
  @@index([recordDate, hallOrgId])
  @@map("hall_task_records")
}

/// 厅管日常任务请假申请
model HallTaskLeaveRequest {
  id              String              @id @default(uuid())
  taskRecordId    String              @map("task_record_id")
  applicantUserId String              @map("applicant_user_id")
  applicantName   String?             @map("applicant_name")
  reason          String              @db.Text
  status          HallTaskLeaveStatus @default(pending)
  reviewedBy      String?             @map("reviewed_by")
  reviewedAt      DateTime?           @map("reviewed_at")
  reviewComment   String?             @map("review_comment") @db.Text
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")
  taskRecord      HallTaskRecord      @relation(fields: [taskRecordId], references: [id])

  @@index([taskRecordId])
  @@index([status])
  @@index([applicantUserId])
  @@map("hall_task_leave_requests")
}

/// 厅管日常任务题目作答记录
model HallTaskItemRecord {
  id              String                 @id @default(uuid())
  taskRecordId    String                 @map("task_record_id")
  taskItemId      String                 @map("task_item_id")
  status          HallTaskItemRecordStatus @default(pending)
  answerText      String?                @map("answer_text") @db.Text
  answerOptions   Json?                  @map("answer_options")
  isLinkConfirmed Boolean                @default(false) @map("is_link_confirmed")
  doneAt          DateTime?              @map("done_at")
  doneBy          String?                @map("done_by")
  createdAt       DateTime               @default(now()) @map("created_at")
  updatedAt       DateTime               @updatedAt @map("updated_at")
  taskRecord      HallTaskRecord         @relation(fields: [taskRecordId], references: [id])
  taskItem        HallTaskItem           @relation(fields: [taskItemId], references: [id])
  attachments     HallTaskItemAttachment[]

  @@unique([taskRecordId, taskItemId])
  @@index([taskRecordId])
  @@index([taskItemId])
  @@map("hall_task_item_records")
}

/// 厅管日常任务题目附件
model HallTaskItemAttachment {
  id                   String             @id @default(uuid())
  hallTaskItemRecordId String             @map("hall_task_item_record_id")
  fileName             String             @map("file_name")
  fileUrl              String             @map("file_url")
  fileSize             Int                @map("file_size")
  mimeType             String             @map("mime_type")
  uploadedBy           String             @map("uploaded_by")
  createdAt            DateTime           @default(now()) @map("created_at")
  hallTaskItemRecord   HallTaskItemRecord @relation(fields: [hallTaskItemRecordId], references: [id])

  @@index([hallTaskItemRecordId])
  @@map("hall_task_item_attachments")
}

enum HallTaskTemplateStatus {
  draft
  archived
}

enum HallTaskItemType {
  QA
  SINGLE_CHOICE
  MULTI_CHOICE
  FILL_BLANK
  LINK
  ATTACHMENT
}

enum HallTaskAssignmentStatus {
  draft
  scheduled
  active
  ended
  deleted
}

enum HallTaskEffectMode {
  immediate
  next_midnight
}

enum HallTaskRecordStatus {
  pending
  in_progress
  submitted
  overdue
}

enum HallTaskItemRecordStatus {
  pending
  done
}

enum HallTaskLeaveStatus {
  pending
  approved
  rejected
  cancelled
}

enum ExportTaskStatus {
  pending
  processing
  done
  failed
}

model ExportTask {
  id        String           @id @default(uuid())
  type      String           // "anchor_profiles"
  status    ExportTaskStatus @default(pending)
  params    Json             // 导出参数快照
  filePath  String?          @map("file_path")
  rowCount  Int?             @map("row_count")
  errorMsg  String?          @map("error_msg") @db.Text
  creatorId String           @map("creator_id")
  creator   User             @relation(fields: [creatorId], references: [id])
  createdAt DateTime         @default(now()) @map("created_at")
  expiresAt DateTime         @map("expires_at")

  @@index([creatorId, type, status])
  @@index([expiresAt])
  @@map("export_tasks")
}

// ════════════════════════════════════════════════════════════
// 厅内直达（Broadcast）任务体系
// ════════════════════════════════════════════════════════════

/// 厅内直达任务主表
model BroadcastTask {
  id                  String                  @id @default(uuid())
  title               String
  description         String?                 @db.Text
  dueAt               DateTime?               @map("due_at")
  createdByUserId     String                  @map("created_by_user_id")
  createdByIdentityId String                  @map("created_by_identity_id")
  createdByName       String                  @map("created_by_name")
  hallOrgId           String                  @map("hall_org_id")
  hallOrgName         String                  @map("hall_org_name")
  status              BroadcastTaskStatus     @default(active)
  createdAt           DateTime                @default(now()) @map("created_at")
  updatedAt           DateTime                @updatedAt @map("updated_at")
  questions           BroadcastQuestion[]
  anchorRecords       BroadcastAnchorRecord[]

  @@index([createdByUserId])
  @@index([hallOrgId])
  @@index([status, dueAt])
  @@map("broadcast_tasks")
}

/// 厅内直达任务题目
model BroadcastQuestion {
  id         String                @id @default(uuid())
  taskId     String                @map("task_id")
  title      String
  itemType   BroadcastQuestionType @map("item_type")
  isRequired Boolean               @map("is_required")
  options    Json                  @default("[]")
  linkUrl    String?               @map("link_url")
  task       BroadcastTask         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  answers    BroadcastAnchorAnswer[]

  @@index([taskId])
  @@map("broadcast_questions")
}

/// 主播参与记录（每任务每主播一条）
model BroadcastAnchorRecord {
  id             String                @id @default(uuid())
  taskId         String                @map("task_id")
  anchorUserId   String                @map("anchor_user_id")
  anchorNickname String                @map("anchor_nickname")
  anchorPhone    String                @map("anchor_phone")
  anchorDouyinNo String?               @map("anchor_douyin_no")
  anchorOrgId    String?               @map("anchor_org_id")
  anchorOrgName  String?               @map("anchor_org_name")
  status         BroadcastAnchorStatus @default(pending)
  submittedAt    DateTime?             @map("submitted_at")
  task           BroadcastTask         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  answers        BroadcastAnchorAnswer[]

  @@unique([taskId, anchorUserId])
  @@index([anchorUserId])
  @@map("broadcast_anchor_records")
}

/// 主播答案（每记录每题目一条）
model BroadcastAnchorAnswer {
  id              String                @id @default(uuid())
  recordId        String                @map("record_id")
  questionId      String                @map("question_id")
  answerText      String?               @db.Text @map("answer_text")
  answerOptions   Json?                 @map("answer_options")
  isLinkConfirmed Boolean?              @map("is_link_confirmed")
  attachmentUrls  Json?                 @map("attachment_urls")
  record          BroadcastAnchorRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  question        BroadcastQuestion     @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([recordId, questionId])
  @@map("broadcast_anchor_answers")
}

enum BroadcastTaskStatus {
  active
  ended
}

enum BroadcastAnchorStatus {
  pending
  in_progress
  submitted
  overdue
}

enum BroadcastQuestionType {
  QA
  FILL_BLANK
  SINGLE_CHOICE
  MULTI_CHOICE
  LINK
  ATTACHMENT
}

// ════════════════════════════════════════════════════════════
// 流转式任务（Workflow）体系
// ════════════════════════════════════════════════════════════

/// 流转式任务主表
model WorkflowTask {
  id                  String             @id @default(uuid())
  title               String
  description         String?            @db.Text
  targetOrgId         String             @map("target_org_id")
  targetOrgName       String             @map("target_org_name")
  issuerOrgId         String?            @map("issuer_org_id")
  issuerOrgName       String?            @map("issuer_org_name")
  issuerScopePath     String?            @map("issuer_scope_path")
  createdByUserId     String             @map("created_by_user_id")
  createdByIdentityId String             @map("created_by_identity_id")
  createdByName       String             @map("created_by_name")
  dueAt               DateTime?          @map("due_at")
  status              WorkflowTaskStatus @default(in_progress)
  currentStepOrder    Int                @default(1) @map("current_step_order")
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")
  steps               WorkflowStep[]

  @@index([createdByUserId])
  @@index([status])
  @@map("workflow_tasks")
}

/// 流转节点
model WorkflowStep {
  id                String             @id @default(uuid())
  taskId            String             @map("task_id")
  order             Int
  title             String
  requirement       String             @db.Text
  assigneeUserId    String             @map("assignee_user_id")
  assigneeName      String             @map("assignee_name")
  assigneeOrgId     String?            @map("assignee_org_id")
  assigneeOrgName   String?            @map("assignee_org_name")
  status            WorkflowStepStatus @default(active)
  submittedAt       DateTime?          @map("submitted_at")
  submittedByUserId String?            @map("submitted_by_user_id")
  completedAt       DateTime?          @map("completed_at")
  task              WorkflowTask       @relation(fields: [taskId], references: [id], onDelete: Cascade)
  questions         WorkflowQuestion[]
  answers           WorkflowAnswer[]

  @@index([taskId])
  @@index([assigneeUserId])
  @@map("workflow_steps")
}

/// 节点题目
model WorkflowQuestion {
  id         String               @id @default(uuid())
  stepId     String               @map("step_id")
  title      String
  itemType   WorkflowQuestionType @map("item_type")
  isRequired Boolean              @map("is_required")
  options    Json                 @default("[]")
  linkUrl    String?              @map("link_url")
  step       WorkflowStep         @relation(fields: [stepId], references: [id], onDelete: Cascade)
  answers    WorkflowAnswer[]

  @@index([stepId])
  @@map("workflow_questions")
}

/// 节点答案（每节点每题目一条）
model WorkflowAnswer {
  id              String           @id @default(uuid())
  stepId          String           @map("step_id")
  questionId      String           @map("question_id")
  answerText      String?          @db.Text @map("answer_text")
  answerOptions   Json?            @map("answer_options")
  isLinkConfirmed Boolean?         @map("is_link_confirmed")
  attachmentUrls  Json?            @map("attachment_urls")
  step            WorkflowStep     @relation(fields: [stepId], references: [id], onDelete: Cascade)
  question        WorkflowQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([stepId, questionId])
  @@map("workflow_answers")
}

enum WorkflowTaskStatus {
  in_progress
  completed
  ended
}

enum WorkflowStepStatus {
  pending
  active
  completed
}

enum WorkflowQuestionType {
  QA
  FILL_BLANK
  SINGLE_CHOICE
  MULTI_CHOICE
  LINK
  ATTACHMENT
}
