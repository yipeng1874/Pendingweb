// 临时任务自动催办：用户级统一配置（一人一行）
model TemporaryNotifySchedule {
  id              String   @id @default(uuid())
  identityId      String   @unique @map("identity_id")
  enabled         Boolean  @default(false)
  prefix          String   @default("来自系统提醒")
  tier1DailyCount Int      @default(2) @map("tier1_daily_count") // ≤1天
  tier2DailyCount Int      @default(1) @map("tier2_daily_count") // 2-3天
  tier3DailyCount Int      @default(1) @map("tier3_daily_count") // 4-7天
  tier4DailyCount Int      @default(0) @map("tier4_daily_count") // 8-15天
  tier5DailyCount Int      @default(0) @map("tier5_daily_count") // >15天
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("temporary_notify_schedules")
}

// 临时任务自动催办：防重流水（每条任务每个时间槽只触发一次）
model TemporaryNotifyTriggerLog {
  id           String   @id @default(uuid())
  assignmentId String   @map("assignment_id")
  slotKey      String   @map("slot_key")
  createdAt    DateTime @default(now()) @map("created_at")

  @@unique([assignmentId, slotKey])
  @@index([assignmentId])
  @@index([createdAt])
  @@map("temporary_notify_trigger_logs")
}

