  taskItemRecordId String         @map("task_item_record_id")
  fileName         String         @map("file_name")
  fileUrl          String         @map("file_url")
  fileSize         Int            @map("file_size")
  mimeType         String         @map("mime_type")
  uploadedBy       String         @map("uploaded_by")
  createdAt        DateTime       @default(now()) @map("created_at")
  taskItemRecord   TaskItemRecord @relation(fields: [taskItemRecordId], references: [id])

  @@index([taskItemRecordId])
  @@map("task_item_attachments")
}

model TaskExemption {
  id           String          @id @default(uuid())
  taskRecordId String          @unique @map("task_record_id")
  userId       String          @map("user_id")
  reason       String          @db.Text
  status       ExemptionStatus @default(pending)
  reviewedBy   String?         @map("reviewed_by")
  reviewedAt   DateTime?       @map("reviewed_at")
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")
  taskRecord   TaskRecord      @relation(fields: [taskRecordId], references: [id])

  @@index([userId])
  @@map("task_exemptions")
}

model PersonalReminder {
  id          String              @id @default(uuid())
  userId      String              @map("user_id")
  title       String
  note        String?             @db.Text
  remindAt    DateTime?           @map("remind_at")
  remindEnd   DateTime?           @map("remind_end")
  remindStart DateTime?           @map("remind_start")
  repeatType  ReminderRepeatType? @map("repeat_type")
